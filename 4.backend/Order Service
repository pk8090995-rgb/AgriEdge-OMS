public with sharing class OrderService {

    public static void processNewOrders(List<Order__c> orders) {
        List<Task> tasks = new List<Task>();

        for (Order__c ord : orders) {
            ord.Status__c = 'Processing';

            Task t = new Task();
            t.Subject = 'Process Order: ' + ord.Name;
            t.WhatId = ord.Id;
            t.Status = 'Not Started';
            t.Priority = 'High';
            tasks.add(t);
        }

        update orders;
        insert tasks;
    }

    public static void updateOrderStatus(Id orderId, String status) {
        Order__c ord = [SELECT Id, Status__c FROM Order__c WHERE Id = :orderId LIMIT 1];
        ord.Status__c = status;
        update ord;
    }
}
